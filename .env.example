# ── HackMatch backend configuration ──────────────────────────
# Copy to `.env` (in the repo root, where you run uvicorn) and fill in.

# Database. SQLite for local dev; Postgres URL in production.
DATABASE_URL=sqlite:///./hackmatch.db

# Anthropic API key — required for the AI / RAG search (/api/search/query)
# and the chat assistant (/api/chat).
ANTHROPIC_API_KEY=

# "Search by Area" geocoding uses free OpenStreetMap Nominatim — no API key.

# JWT / auth
SECRET_KEY=changethisinproduction

# ── Transactional email (Resend) ─────────────────────────────
# Needed to ACTUALLY send emails (welcome, sign-in, and owner notifications).
# Without RESEND_API_KEY, emails are logged instead of sent.
RESEND_API_KEY=
EMAIL_FROM=HackMatch <onboarding@resend.dev>

# Owner notifications: get an email whenever someone signs up or signs in.
# Set this to YOUR email. Leave empty to disable.
ADMIN_NOTIFY_EMAIL=

# Email (legacy Gmail SMTP — unused once Resend is set)
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
