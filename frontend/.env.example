# ── HackMatch frontend configuration ─────────────────────────
# Copy to `frontend/.env` and fill in. CRA only exposes vars prefixed REACT_APP_.

# Backend API base URL
REACT_APP_API_URL=http://127.0.0.1:8000

# Google Maps JS API key — enables the interactive map + city autocomplete
# on the "Search by Area" page. Needs the "Maps JavaScript API" and
# "Places API" enabled in Google Cloud Console.
REACT_APP_GOOGLE_MAPS_API_KEY=
